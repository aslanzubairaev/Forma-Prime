# Telegram bot token from BotFather. Required for `npm run dev` / `npm start`.
BOT_TOKEN=replace-with-telegram-bot-token

# Supabase Postgres connection strings. Supabase is used only as PostgreSQL.
DATABASE_URL=postgresql://postgres:[password]@[host]:6543/postgres?pgbouncer=true&connection_limit=1
DIRECT_URL=postgresql://postgres:[password]@[host]:5432/postgres

LOG_LEVEL=info

# Optional OpenAI provider for AI food draft fallback.
# Without OPENAI_API_KEY, food draft parsing is safely unavailable.
OPENAI_API_KEY=
OPENAI_FOOD_DRAFT_MODEL=gpt-4.1-mini
